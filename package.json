{
  "name": "@ewei/relayer",
  "version": "1.2.0",
  "description": "Open-source relay node for the eWei gas sponsorship protocol on BNB Smart Chain",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/ tests/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "node dist/db/migrate.js",
    "docker:build": "docker build -t ewei-relayer .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "keywords": ["bnb", "bsc", "gas-sponsorship", "relayer", "meta-transactions", "ewei", "web3"],
  "author": "eWei Protocol <dev@ewei.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eWeiBNB/ewei-relayer.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "dotenv": "^16.3.1",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.5",
    "zod": "^3.22.4",
    "uuid": "^9.0.0",
    "cron": "^3.1.6",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.2",
    "tsx": "^4.6.2",
    "vitest": "^1.1.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2"
  }
}
