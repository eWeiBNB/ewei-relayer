# ── Node ────────────────────────────────────────────
NODE_ENV=production
PORT=3100
LOG_LEVEL=info

# ── BNB Smart Chain ─────────────────────────────────
BSC_RPC_URL=https://bsc-dataseed1.binance.org
BSC_RPC_URL_FALLBACK=https://bsc-dataseed2.binance.org
BSC_CHAIN_ID=56
BSC_EXPLORER_URL=https://bscscan.com

# ── Hot Wallet ──────────────────────────────────────
RELAYER_PRIVATE_KEY=0x...
MIN_BALANCE_THRESHOLD=0.05
MAX_GAS_PRICE_GWEI=10

# ── eWei Contracts ──────────────────────────────────
EWEI_FORWARDER_ADDRESS=0x...
EWEI_POLICY_REGISTRY_ADDRESS=0x...
EWEI_STAKING_ADDRESS=0x...

# ── PostgreSQL ──────────────────────────────────────
DATABASE_URL=postgres://ewei:password@localhost:5432/ewei_relayer
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=ewei:relayer:

# ── API Authentication ──────────────────────────────
API_KEYS=
API_KEYS_FROM_DB=true

# ── Rate Limiting ───────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Monitoring ──────────────────────────────────────
METRICS_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL_MS=30000

# ── Webhooks ────────────────────────────────────────
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_MAX_RETRIES=3

# ── Gas Oracle ──────────────────────────────────────
GAS_ORACLE_UPDATE_INTERVAL_MS=12000
GAS_PRICE_BUMP_PERCENT=10
GAS_SPIKE_THRESHOLD_GWEI=8
